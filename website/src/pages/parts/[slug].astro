---
// website/src/pages/parts/[slug].astro
import '../../styles/global.css';
import fs from 'fs';
import path from 'path';
import { marked } from 'marked';
import StlViewer from '../../components/StlViewer.astro';

export async function getStaticPaths() {
  // 1. Load the database generated by build-db.js
  const dbPath = path.resolve('./public/models.json');
  const models = JSON.parse(fs.readFileSync(dbPath, 'utf8'));

  // 2. Tell Astro to generate a route for every model
  return models.map((model) => {
    // Attempt to read the description.md file for this specific part
    const mdPath = path.resolve(`../parts/${model.slug}/description.md`);
    let descriptionHtml = '<p>No description provided.</p>';
    
    if (fs.existsSync(mdPath)) {
      const rawMarkdown = fs.readFileSync(mdPath, 'utf8');
      let html = marked.parse(rawMarkdown);
      
      // Get the base URL to ensure it works on both local dev and GitHub Pages CI
      const baseUrl = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
      
      // Rewrite relative image sources and file links
      html = html.replace(/(src|href)="([^"]+)"/g, (match, attr, pathStr) => {
        // Ignore absolute URLs, data URIs, mailto links, and anchor tags
        if (!pathStr.startsWith('http') && !pathStr.startsWith('data:') && !pathStr.startsWith('/') && !pathStr.startsWith('mailto:') && !pathStr.startsWith('#')) {
          // Point the link explicitly to the part's public folder
          return `${attr}="${baseUrl}/parts/${model.slug}/${pathStr}"`;
        }
        return match;
      });

      descriptionHtml = html;
    }

    // 3. Pass the model data and rendered markdown as 'props' to the page
    return {
      params: { slug: model.slug },
      props: { model, descriptionHtml },
    };
  });
}

// Extract the props passed from getStaticPaths
const { model, descriptionHtml } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{model.title} - OpenPartVault</title>
    <style>
      body { font-family: system-ui, sans-serif; background: #fafafa; color: #333; margin: 0; padding: 0; }
      .container { max-width: 1000px; margin: 0 auto; padding: 2rem; }
      header { border-bottom: 1px solid #ddd; padding-bottom: 1rem; margin-bottom: 2rem; }
      .tags { display: flex; gap: 0.5rem; margin-top: 1rem; }
      .tag { background: #e0e0e0; padding: 0.25rem 0.75rem; border-radius: 99px; font-size: 0.85rem; }
      .viewer-container { border: 1px solid #ddd; border-radius: 8px; overflow: hidden; background: #fff; margin-bottom: 2rem; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
      .files-list { list-style: none; padding: 0; display: flex; gap: 1rem; flex-wrap: wrap; }
      .download-btn { display: inline-block; background: #0366d6; color: #fff; padding: 0.5rem 1rem; text-decoration: none; border-radius: 4px; font-weight: bold; }
      .download-btn:hover { background: #005cc5; }
      .description { background: #fff; padding: 2rem; border-radius: 8px; border: 1px solid #ddd; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header-row" style="margin-bottom: 1rem;">
        <a href={`${import.meta.env.BASE_URL}/`}>&larr; Back to Vault</a>
        <a href={`https://github.com/jdegenstein/OpenPartVault/tree/main/parts/${model.slug}`} target="_blank" rel="noopener noreferrer" class="github-link">
          View Folder on GitHub
        </a>
      </div>
      
      <header>
        <h1>{model.title}</h1>
        <p>Created by <strong>{model.author}</strong> using {model.cad_software} | Added: {model.date_added}</p>
        <div class="tags">
          {model.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </header>

      <div class="viewer-container">
        {model.stlFiles && model.stlFiles.length > 0 ? (
          <StlViewer slug={model.slug} stlFiles={model.stlFiles} />
        ) : (
          <div style="padding: 3rem; text-align: center; color: #666;">
            <p>No STL files available for 3D preview.</p>
          </div>
        )}
      </div>

      <section>
        <h2>Downloads</h2>
        <ul class="files-list">
          {model.files.map((file) => (
            <li>
              <a href={`${import.meta.env.BASE_URL}/parts/${model.slug}/${file}`} download class="download-btn">
              Download {file}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="description">
        <h2>Description</h2>
        <article set:html={descriptionHtml} />
      </section>
    </div>


    <script>
      // Wait for the DOM to fully load
      document.addEventListener("DOMContentLoaded", () => {
        // Find all code blocks inside the description section
        const preElements = document.querySelectorAll('.description pre');

        preElements.forEach((pre) => {
          const codeElem = pre.querySelector('code');
          if (!codeElem) return;

          // Extract the language name from the class (e.g., "language-python")
          let lang = 'TEXT';
          codeElem.classList.forEach(cls => {
            if (cls.startsWith('language-')) {
              lang = cls.replace('language-', '');
            }
          });

          // Create the outer wrapper
          const wrapper = document.createElement('div');
          wrapper.className = 'code-wrapper';
          
          // Insert wrapper just before the pre element, then move the pre inside it
          pre.parentNode.insertBefore(wrapper, pre);
          
          // Create the header bar
          const header = document.createElement('div');
          header.className = 'code-header';
          
          // Add the language label
          const langSpan = document.createElement('span');
          langSpan.className = 'code-lang';
          langSpan.innerText = lang;
          
          // Add the copy button
          const copyBtn = document.createElement('button');
          copyBtn.className = 'copy-btn';
          copyBtn.innerText = 'Copy';
          
          // Attach copy functionality
          copyBtn.addEventListener('click', async () => {
            try {
              // Write the text content of the code block to the clipboard
              await navigator.clipboard.writeText(codeElem.innerText);
              
              // Visual feedback
              copyBtn.innerText = 'Copied!';
              copyBtn.classList.add('copied');
              
              // Reset button after 2 seconds
              setTimeout(() => {
                copyBtn.innerText = 'Copy';
                copyBtn.classList.remove('copied');
              }, 2000);
            } catch (err) {
              console.error('Failed to copy text: ', err);
            }
          });

          // Assemble the DOM structure
          header.appendChild(langSpan);
          header.appendChild(copyBtn);
          
          wrapper.appendChild(header);
          wrapper.appendChild(pre);
        });
      });
    </script>
  </body>
</html>
