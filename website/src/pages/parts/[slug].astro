---
// website/src/pages/parts/[slug].astro
import '../../styles/global.css';
import fs from 'fs';
import path from 'path';
import { marked } from 'marked';
import StlViewer from '../../components/StlViewer.astro';

export async function getStaticPaths() {
  // 1. Load the database generated by build-db.js
  const dbPath = path.resolve('./public/models.json');
  const models = JSON.parse(fs.readFileSync(dbPath, 'utf8'));

  // 2. Tell Astro to generate a route for every model
  return models.map((model) => {
    // Attempt to read the description.md file for this specific part
    const mdPath = path.resolve(`../parts/${model.slug}/description.md`);
    let descriptionHtml = '<p>No description provided.</p>';
    
    if (fs.existsSync(mdPath)) {
      const rawMarkdown = fs.readFileSync(mdPath, 'utf8');
      descriptionHtml = marked.parse(rawMarkdown);
    }

    // 3. Pass the model data and rendered markdown as 'props' to the page
    return {
      params: { slug: model.slug },
      props: { model, descriptionHtml },
    };
  });
}

// Extract the props passed from getStaticPaths
const { model, descriptionHtml } = Astro.props;

// Use import.meta.env.BASE_URL for the STL link
const baseUrl = import.meta.env.BASE_URL;
const stlUrl = model.stlFile ? `${baseUrl}parts/${model.slug}/${model.stlFile}` : null;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{model.title} - OpenPartVault</title>
    <style>
      body { font-family: system-ui, sans-serif; background: #fafafa; color: #333; margin: 0; padding: 0; }
      .container { max-width: 1000px; margin: 0 auto; padding: 2rem; }
      header { border-bottom: 1px solid #ddd; padding-bottom: 1rem; margin-bottom: 2rem; }
      .tags { display: flex; gap: 0.5rem; margin-top: 1rem; }
      .tag { background: #e0e0e0; padding: 0.25rem 0.75rem; border-radius: 99px; font-size: 0.85rem; }
      .viewer-container { border: 1px solid #ddd; border-radius: 8px; overflow: hidden; background: #fff; margin-bottom: 2rem; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
      .files-list { list-style: none; padding: 0; display: flex; gap: 1rem; flex-wrap: wrap; }
      .download-btn { display: inline-block; background: #0366d6; color: #fff; padding: 0.5rem 1rem; text-decoration: none; border-radius: 4px; font-weight: bold; }
      .download-btn:hover { background: #005cc5; }
      .description { background: #fff; padding: 2rem; border-radius: 8px; border: 1px solid #ddd; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header-row" style="margin-bottom: 1rem;">
        <a href={import.meta.env.BASE_URL}>&larr; Back to Vault</a>
        <a href={`https://github.com/jdegenstein/OpenPartVault/tree/main/parts/${model.slug}`} target="_blank" rel="noopener noreferrer" class="github-link">
          View Folder on GitHub
        </a>
      </div>
      
      <header>
        <h1>{model.title}</h1>
        <p>Created by <strong>{model.author}</strong> using {model.cad_software} | Added: {model.date_added}</p>
        <div class="tags">
          {model.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </header>

      <div class="viewer-container">
        {stlUrl ? (
          <StlViewer stlUrl={stlUrl} />
        ) : (
          <div style="padding: 3rem; text-align: center; color: #666;">
            <p>No STL file available for 3D preview.</p>
          </div>
        )}
      </div>

      <section>
        <h2>Downloads</h2>
        <ul class="files-list">
          {model.files.map((file) => (
            <li>
                <a href={`${import.meta.env.BASE_URL}parts/${model.slug}/${file}`} download class="download-btn">
                  Download {file}
                </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="description">
        <h2>Description</h2>
        <article set:html={descriptionHtml} />
      </section>
    </div>
  </body>
</html>
