---
import '../../styles/global.css';
import fs from 'fs';
import path from 'path';
import { marked } from 'marked';
import StlViewer from '../../components/StlViewer.astro';

export async function getStaticPaths() {
  const dbPath = path.resolve('./public/models.json');
  const models = JSON.parse(fs.readFileSync(dbPath, 'utf8'));

  return models.map((model) => {
    const mdPath = path.resolve(`../parts/${model.slug}/description.md`);
    let descriptionHtml = '<p>No description provided.</p>';
    
    if (fs.existsSync(mdPath)) {
      const rawFile = fs.readFileSync(mdPath, 'utf8');
      let html = marked.parse(rawFile);
      
      const baseUrl = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
      html = html.replace(/(src|href)="([^"]+)"/g, (match, attr, pathStr) => {
        if (!pathStr.startsWith('http') && !pathStr.startsWith('data:') && !pathStr.startsWith('/') && !pathStr.startsWith('mailto:') && !pathStr.startsWith('#')) {
          return `${attr}="${baseUrl}/parts/${model.slug}/${pathStr}"`;
        }
        return match;
      });
      descriptionHtml = html;
    }

    return {
      params: { slug: model.slug },
      props: { model, descriptionHtml },
    };
  });
}

const { model, descriptionHtml } = Astro.props;
const baseUrl = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

// Build the hierarchical file tree
const fileTree = {};
model.files.forEach(f => {
  // Extract path and size from our updated database object
  const filePath = f.name;
  const fileSize = f.size;
  
  const parts = filePath.split('/');
  let current = fileTree;
  for (let i = 0; i < parts.length - 1; i++) {
    if (!current[parts[i]]) current[parts[i]] = {};
    current = current[parts[i]];
  }
  // Mark the leaf node securely and attach data
  current[parts[parts.length - 1]] = { _isFile: true, path: filePath, size: fileSize }; 
});

// Recursive function to render folders first, then files
function renderTree(node) {
  let html = '<ul class="file-tree-list">';
  const keys = Object.keys(node);
  
  keys.sort((a, b) => {
    const aIsFolder = !node[a]._isFile;
    const bIsFolder = !node[b]._isFile;
    if (aIsFolder && !bIsFolder) return -1;
    if (!aIsFolder && bIsFolder) return 1;
    return a.localeCompare(b);
  });

  keys.forEach(key => {
    if (!node[key]._isFile) {
      html += `
        <li class="tree-node">
          <details>
            <summary class="folder-summary">
              <span class="icon">📁</span> 
              <span class="folder-name">${key}</span>
            </summary>
            ${renderTree(node[key])}
          </details>
        </li>`;
    } else {
      const fileData = node[key];
      html += `
        <li class="tree-node">
          <div class="file-row">
            <div class="file-name-col">
              <span class="icon">📄</span> 
              <span class="file-name">${key}</span>
            </div>
            <div class="file-size-col">${fileData.size}</div>
            <div class="file-action-col">
              <a href="${baseUrl}/parts/${model.slug}/${fileData.path}" download class="download-btn small">
                <svg class="dl-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                Download
              </a>
            </div>
          </div>
        </li>`;
    }
  });
  html += '</ul>';
  return html;
}

const fileTreeHtml = renderTree(fileTree);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{model.title} - OpenPartVault</title>
    <style>
      body { font-family: system-ui, sans-serif; background: #fafafa; color: #333; margin: 0; padding: 0; }
      .container { max-width: 1000px; margin: 0 auto; padding: 2rem; }
      header { border-bottom: 1px solid #ddd; padding-bottom: 1rem; margin-bottom: 2rem; }
      .tags { display: flex; gap: 0.5rem; margin-top: 1rem; }
      .tag { background: #e0e0e0; padding: 0.25rem 0.75rem; border-radius: 99px; font-size: 0.85rem; }
      .viewer-container { border: 1px solid #ddd; border-radius: 8px; overflow: hidden; background: #fff; margin-bottom: 1rem; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
      .download-btn { display: inline-block; background: #0366d6; color: #fff; padding: 0.5rem 1rem; text-decoration: none; border-radius: 4px; font-weight: bold; white-space: nowrap; }
      .download-btn:hover { background: #005cc5; }
      .download-btn.small { padding: 0.25rem 0.5rem; font-size: 0.8rem; }
      
      /* Tabs UI */
      .action-row { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 2px solid #ddd; margin-bottom: 1.5rem; }
      .tabs { display: flex; gap: 0.5rem; }
      .tab-btn { background: none; border: none; font-size: 1.1rem; font-weight: bold; color: #666; padding: 0.75rem 1.5rem; cursor: pointer; border-bottom: 3px solid transparent; margin-bottom: -2px; }
      .tab-btn:hover { color: #333; }
      .tab-btn.active { color: #0366d6; border-bottom-color: #0366d6; }
      .tab-content { display: none; background: #fff; padding: 2rem; border-radius: 8px; border: 1px solid #ddd; }
      .tab-content.active { display: block; }
      .download-all-container { padding-bottom: 0.5rem; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header-row" style="margin-bottom: 1rem;">
        <a href={`${baseUrl}/`}>&larr; Back to Vault</a>
        <a href={`https://github.com/jdegenstein/OpenPartVault/tree/main/parts/${model.slug}`} target="_blank" rel="noopener noreferrer" class="github-link">
          View Folder on GitHub
        </a>
      </div>
      
      <header>
        <h1>{model.title}</h1>
        <p>Created by <strong>{model.author}</strong> using {model.cad_software} | Added: {model.date_added}</p>
        <div class="tags">
          {model.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </header>

      <div class="viewer-container">
        {model.stlFiles && model.stlFiles.length > 0 ? (
          <StlViewer slug={model.slug} stlFiles={model.stlFiles} />
        ) : (
          <div style="padding: 3rem; text-align: center; color: #666;">
            <p>No STL files available for 3D preview.</p>
          </div>
        )}
      </div>

      <div class="action-row">
        <div class="tabs">
          <button class="tab-btn active" onclick="switchTab('details')">Details</button>
          <button class="tab-btn" onclick="switchTab('files')">Files</button>
        </div>
        <div class="download-all-container">
          <a href={`${baseUrl}/parts/${model.slug}/${model.zipUrl}`} download class="download-btn">
            📥 Download All (.zip)
          </a>
        </div>
      </div>

      <div id="tab-details" class="tab-content active description">
        <article set:html={descriptionHtml} />
      </div>

      <div id="tab-files" class="tab-content">
        <h3>Repository Files</h3>
        <div set:html={fileTreeHtml}></div>
      </div>

    </div>

    <script>
      // Tab switching logic attached to window for inline onclick access
      window.switchTab = function(tabName) {
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
        
        event.target.classList.add('active');
        document.getElementById(`tab-${tabName}`).classList.add('active');
      };

      document.addEventListener("DOMContentLoaded", () => {
        const preElements = document.querySelectorAll('.description pre');
        preElements.forEach((pre) => {
          const codeElem = pre.querySelector('code');
          if (!codeElem) return;

          let lang = 'TEXT';
          codeElem.classList.forEach(cls => {
            if (cls.startsWith('language-')) lang = cls.replace('language-', '');
          });

          const wrapper = document.createElement('div');
          wrapper.className = 'code-wrapper';
          pre.parentNode.insertBefore(wrapper, pre);
          
          const header = document.createElement('div');
          header.className = 'code-header';
          
          const langSpan = document.createElement('span');
          langSpan.className = 'code-lang';
          langSpan.innerText = lang;
          
          const copyBtn = document.createElement('button');
          copyBtn.className = 'copy-btn';
          copyBtn.innerText = 'Copy';
          
          copyBtn.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(codeElem.innerText);
              copyBtn.innerText = 'Copied!';
              copyBtn.classList.add('copied');
              setTimeout(() => {
                copyBtn.innerText = 'Copy';
                copyBtn.classList.remove('copied');
              }, 2000);
            } catch (err) {
              console.error('Failed to copy text: ', err);
            }
          });

          header.appendChild(langSpan);
          header.appendChild(copyBtn);
          wrapper.appendChild(header);
          wrapper.appendChild(pre);
        });
      });
    </script>
  </body>
</html>
