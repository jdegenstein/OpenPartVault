---
// website/src/components/Search.astro
// No server-side logic needed here, as it's a client-side interaction
---

<div id="vault-search-root" class="search-container">
  <div class="controls">
    <input 
      type="text" 
      id="search-input" 
      placeholder="Search parts (e.g. M4, Stepper, build123d)..." 
    />
    
    <div class="filter-row">
      <select id="sort-select">
        <option value="newest">Date: Newest</option>
        <option value="oldest">Date: Oldest</option>
        <option value="az">Title: A-Z</option>
      </select>
      
      <div id="tag-cloud" class="tag-cloud">
        </div>
    </div>
  </div>

  <div id="results-grid" class="results-grid">
    </div>
</div>

<script>
  import Fuse from 'fuse.js';

  let models = [];
  let fuse = null;
  let activeTags = new Set();
  let currentSort = 'newest';

  const grid = document.getElementById('results-grid');
  const input = document.getElementById('search-input');
  const sortSelect = document.getElementById('sort-select');
  const tagCloud = document.getElementById('tag-cloud');

  async function init() {
    // 1. Fetch the data generated by build-db.js
    const response = await fetch('/models.json');
    models = await response.json();

    // 2. Setup Fuse.js
    fuse = new Fuse(models, {
      keys: ['title', 'tags', 'cad_software'],
      threshold: 0.3
    });

    // 3. Extract unique tags for the filter UI
    const allTags = [...new Set(models.flatMap(m => m.tags))];
    renderTags(allTags);

    // Initial render
    updateResults();
  }

  function renderTags(tags) {
    tagCloud.innerHTML = tags.map(tag => `
      <button class="tag-pill" data-tag="${tag}">${tag}</button>
    `).join('');

    tagCloud.querySelectorAll('.tag-pill').forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.tag;
        if (activeTags.has(tag)) activeTags.delete(tag);
        else activeTags.add(tag);
        btn.classList.toggle('active');
        updateResults();
      });
    });
  }

  function updateResults() {
    const query = input.value;
    let results = query ? fuse.search(query).map(r => r.item) : models;

    // Filter by tags
    if (activeTags.size > 0) {
      results = results.filter(m => m.tags.some(t => activeTags.has(t)));
    }

    // Sort
    results.sort((a, b) => {
      if (currentSort === 'newest') return new Date(b.date_added) - new Date(a.date_added);
      if (currentSort === 'oldest') return new Date(a.date_added) - new Date(b.date_added);
      if (currentSort === 'az') return a.title.localeCompare(b.title);
    });

    renderGrid(results);
  }

  function renderGrid(items) {
    grid.innerHTML = items.map(item => `
      <a href="/parts/${item.slug}" class="model-card">
        <img src="/parts/${item.slug}/thumbnail.png" alt="${item.title}" loading="lazy" />
        <div class="card-info">
          <h3>${item.title}</h3>
          <p>By ${item.author}</p>
          <div class="card-tags">
            ${item.tags.map(t => `<span class="tag">${t}</span>`).join('')}
          </div>
        </div>
      </a>
    `).join('');
  }

  input.addEventListener('input', updateResults);
  sortSelect.addEventListener('change', (e) => {
    currentSort = e.target.value;
    updateResults();
  });

  init();
</script>
